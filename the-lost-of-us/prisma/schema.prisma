generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

model comments {
  id           String   @id @db.Uuid
  post_id      String   @db.Uuid
  user_sub     String   @db.Uuid
  comment_text String
  created_at   DateTime @default(now()) @db.Timestamp(6)
  posts        posts    @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comments_post")
  users        users    @relation(fields: [user_sub], references: [user_sub], onDelete: Cascade, onUpdate: NoAction, map: "fk_comments_user")
}

model petimages {
  id        String @id @db.Uuid
  post_id   String @db.Uuid
  image_uri String
  posts     posts  @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_petimages_post")
}

model posts {
  id                 String                    @id @db.Uuid
  user_sub           String                    @db.Uuid
  pet_name           String
  description        String?
  last_seen_location Unsupported("geography")?
  last_seen_date     DateTime?                 @db.Timestamp(6)
  created_at         DateTime                  @default(now()) @db.Timestamp(6)
  comments           comments[]
  petimages          petimages[]
  users              users                     @relation(fields: [user_sub], references: [user_sub], onDelete: Cascade, onUpdate: NoAction, map: "fk_posts_user")
  sightings          sightings[]
}

model sightings {
  id          String                   @id @db.Uuid
  post_id     String                   @db.Uuid
  location    Unsupported("geography")
  description String?
  reported_at DateTime                 @default(now()) @db.Timestamp(6)
  posts       posts                    @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sightings_post")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model users {
  id                String     @id @db.Uuid
  user_sub          String     @unique @db.Uuid
  profile_image_uri String?
  created_at        DateTime   @default(now()) @db.Timestamp(6)
  comments          comments[]
  posts             posts[]
}
