generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model comments {
  id                String            @id @default(uuid()) @db.Uuid
  post_id           String            @db.Uuid
  parent_comment_id String?           @db.Uuid
  user_sub          String
  comment_text      String
  likes_count       Int               @default(0)
  dislikes_count    Int               @default(0)
  reports_count     Int               @default(0)
  created_at        DateTime          @default(now()) @db.Timestamp(6)
  updated_at        DateTime          @default(now()) @updatedAt @db.Timestamp(6)
  posts             posts             @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comments_post")
  parent_comment    comments?         @relation("comment_replies", fields: [parent_comment_id], references: [id], onDelete: Cascade)
  replies           comments[]        @relation("comment_replies")
  comment_votes     comment_votes[]
  comment_reports   comment_reports[]

  @@index([post_id, parent_comment_id])
}

model comment_votes {
  id         String   @id @default(uuid()) @db.Uuid
  comment_id String   @db.Uuid
  user_sub   String
  value      Int
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(6)
  comments   comments @relation(fields: [comment_id], references: [id], onDelete: Cascade)

  @@unique([comment_id, user_sub])
  @@index([comment_id])
}

model comment_reports {
  id          String   @id @default(uuid()) @db.Uuid
  comment_id  String   @db.Uuid
  user_sub    String
  reason      String?
  created_at  DateTime @default(now()) @db.Timestamp(6)
  comments    comments @relation(fields: [comment_id], references: [id], onDelete: Cascade)

  @@unique([comment_id, user_sub])
  @@index([comment_id])
}

model petimages {
  id        String @id @db.Uuid
  post_id   String @db.Uuid
  image_uri String
  posts     posts  @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_petimages_post")
}

model posts {
  id                 String                    @id @db.Uuid
  user_sub           String
  user_sub           String
  pet_name           String
  description        String?
  last_seen_location Unsupported("geography")?
  last_seen_date     DateTime?                 @db.Timestamp(6)
  created_at         DateTime                  @default(now()) @db.Timestamp(6)
  comments           comments[]
  petimages          petimages[]
  sightings          sightings[]
}

model sightings {
  id          String                   @id @db.Uuid
  post_id     String                   @db.Uuid
  location    Unsupported("geography")
  description String?
  reported_at DateTime                 @default(now()) @db.Timestamp(6)
  posts       posts                    @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sightings_post")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}
